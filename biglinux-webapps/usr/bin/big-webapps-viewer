# optional MPRIS integration for media webapps
try:
    # resolve import path relative to the script
    _mpris_dir = Path(__file__).resolve().parent.parent / "share/biglinux/webapps"
    sys.path.insert(0, str(_mpris_dir))
    from webapps.utils.mpris import (
        MPRIS_AVAILABLE,
        MprisService,
        MEDIA_SESSION_JS,
        start_glib_loop,
    )

    sys.path.pop(0)
except ImportError:
    MPRIS_AVAILABLE = False
    MEDIA_SESSION_JS = ""

